{
	"tasks": {
		"dev": "deno run -P=default --watch src/mod.ts"
	},
	"permissions": {
		"default": {
			"net": true,
			"read": true
		}
	},
	"imports": {
		"@musicorum/lastfm": "npm:@musicorum/lastfm@^0.4.0",
		"~/": "./src/",
		"@minify-html/deno": "jsr:@minify-html/deno@^0.18.1",
		"@std/path": "jsr:@std/path@^1.1.4",
		"@july/snarl": "jsr:@july/snarl@^0.3.3",
		"@std/encoding": "jsr:@std/encoding@^1.0.10"
	},
	"fmt": {
		"useTabs": true,
		"semiColons": true,
		"lineWidth": 120,
		"exclude": [
			"./src/hash/meowmix1.ts"
		]
	},
	"compilerOptions": {
		"jsx": "react-jsx",
		"jsxImportSource": "@july/snarl",
		"lib": ["deno.ns", "dom", "dom.iterable"]
	},
	"lint": {
		"rules": {
			"tags": ["recommended"],
			"exclude": ["no-explicit-any"]
		}
	}
}
